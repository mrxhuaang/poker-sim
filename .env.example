# Firebase (cuarto, lobby, cartas) — config web PUBLICA (va al bundle).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (SOLO servidor — NO usar prefijo NEXT_PUBLIC).
# Autoridad del wallet/XP en /api/economy. Genera la clave en:
# Firebase Console > Configuracion del proyecto > Cuentas de servicio >
# "Generar nueva clave privada". Del JSON descargado:
#   client_email  -> FIREBASE_ADMIN_CLIENT_EMAIL
#   private_key   -> FIREBASE_ADMIN_PRIVATE_KEY (con los \n literales)
# En Vercel: pega la private_key entera entre comillas; los \n se respetan.
# project_id cae a NEXT_PUBLIC_FIREBASE_PROJECT_ID si se omite.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Supabase — Realtime (señalización de voz) Y persistencia durable (stats/historial).
# URL + anon key son PUBLICAS (van al bundle, solo lectura via RLS).
# Proyecto: poker-sim (ref fpbmrxfcrphrjwwegqsn). Ver docs/voice-setup.md
# y docs/persistence-setup.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (SOLO servidor — NO usar prefijo NEXT_PUBLIC, NO commitear).
# Autoridad de escritura para stats/historial: las mutaciones pasan por el server
# (route handler) que verifica el idToken de Firebase y escribe con esta clave,
# saltando RLS — mismo patron que FIREBASE_ADMIN_* en /api/economy.
# Copiala de: Supabase Dashboard > Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# TURN server para WebRTC (recomendado Metered.ca free tier, 50 GB/mes).
# Aviso: estas credenciales son visibles en el bundle del cliente.
# Para deploy público, considerar Route Handler que firme credenciales temporales.
# Detalles en docs/voice-setup.md.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_URL_TLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
