# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# also ignore dot-less env files (.env* does NOT match `env.local`)
env.local
env*.local
*.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# rust engine (build output; Cargo.lock IS committed for reproducible CI)
/engine/target
/engine/pkg
server/bin/
